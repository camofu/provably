# Config for the tlsn/reseller prover, loaded via dotenv (it searches up from the
# working directory, so the repo-root `.env` is found from `tlsn/reseller`).
# Copy this to `.env` at the repo root and fill in your key. `.env` is gitignored.
#
# The reseller is upstream-agnostic; the values below proxy Anthropic as an example.

# The TLS server to proxy and attest (required).
UPSTREAM_HOST=api.anthropic.com

# Secret API key, injected as the x-api-key header and redacted from the proof.
UPSTREAM_API_KEY=sk-ant-your-key-here

# Extra request headers to inject, "Name: Value; Name2: Value2".
UPSTREAM_HEADERS=anthropic-version: 2023-06-01
